{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information",
      "type": "object",
      "properties": {
        "full_name": { "type": "string", "description": "User's full name" },
        "branch": { "type": "string", "description": "User's branch/specialty" },
        "role": { "type": "string", "enum": ["student", "admin"], "description": "User's role" },
        "points": { "type": "integer", "description": "User's points" },
        "avatar_url": { "type": "string", "description": "User's avatar URL" },
        "created_at": { "type": "string", "format": "date-time", "description": "Profile creation timestamp" }
      },
      "required": ["full_name", "branch", "role"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in the community feed",
      "type": "object",
      "properties": {
        "author_id": { "type": "string", "description": "UID of the author" },
        "author_name": { "type": "string", "description": "Name of the author" },
        "content": { "type": "string", "description": "Content of the post" },
        "subject": { "type": "string", "description": "Subject of the post" },
        "likes_count": { "type": "integer", "description": "Number of likes" },
        "created_at": { "type": "string", "format": "date-time", "description": "Post creation timestamp" }
      },
      "required": ["author_id", "content", "subject", "created_at"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat group",
      "type": "object",
      "properties": {
        "group_id": { "type": "string", "description": "ID of the chat group" },
        "sender_id": { "type": "string", "description": "UID of the sender" },
        "sender_name": { "type": "string", "description": "Name of the sender" },
        "text": { "type": "string", "description": "Message text" },
        "created_at": { "type": "string", "format": "date-time", "description": "Message creation timestamp" }
      },
      "required": ["group_id", "sender_id", "text", "created_at"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "maintenance_mode": { "type": "boolean", "description": "Whether the app is in maintenance mode" }
      }
    },
    "QuizSession": {
      "title": "Quiz Session",
      "description": "A completed quiz session",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "UID of the user" },
        "user_name": { "type": "string", "description": "Name of the user" },
        "score": { "type": "integer", "description": "Quiz score" },
        "total_questions": { "type": "integer", "description": "Total number of questions" },
        "subject": { "type": "string", "description": "Subject of the quiz" },
        "created_at": { "type": "string", "format": "date-time", "description": "Session creation timestamp" }
      },
      "required": ["user_id", "score", "total_questions", "subject", "created_at"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A system notification",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Notification title" },
        "message": { "type": "string", "description": "Notification message" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "error"], "description": "Notification type" },
        "created_at": { "type": "string", "format": "date-time", "description": "Notification creation timestamp" }
      },
      "required": ["title", "message", "type", "created_at"]
    },
    "ApiKeys": {
      "title": "API Keys",
      "description": "Stores API keys for various services",
      "type": "object",
      "properties": {
        "settings": { "type": "object", "description": "API keys settings" }
      }
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts"
    },
    "/quiz_sessions/{sessionId}": {
      "schema": "QuizSession",
      "description": "Quiz results"
    },
    "/chat_groups/{groupId}": {
      "schema": { "type": "object", "properties": { "name": { "type": "string" } } },
      "description": "Chat groups"
    },
    "/chat_groups/{groupId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat group"
    },
    "/admin_settings/general": {
      "schema": "AdminSettings",
      "description": "Global app settings"
    },
    "/admin_settings/api_keys": {
      "schema": "ApiKeys",
      "description": "API keys settings"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications"
    }
  }
}
